{
  "compilerOptions": {
    "module": "node16",
    "moduleResolution": "node16",
        "paths": {
      "@/*": ["./src/*"]
    },
    "esModuleInterop": true, // hỗ trợ import giữa ESM và CommonJS
    "isolatedModules": true,
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2023", // biên dịch sang JS phiên bản 2023
    "sourceMap": true,
    "outDir": "./dist",
    "incremental": true,
    "skipLibCheck": true,
    "strictNullChecks": true,
    "forceConsistentCasingInFileNames": true,
    "noImplicitAny": false,
    "strictBindCallApply": false,
    "noFallthroughCasesInSwitch": false,
    "types": ["multer"]
  }
}
