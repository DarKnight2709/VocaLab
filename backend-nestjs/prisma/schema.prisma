// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

// sau khi chạy npx prisma generate
// sẽ có PrismaClient ở file output
generator client {
  provider = "prisma-client-js"
}

// khai báo để biết 
//  - Dùng adapter PostgreSQL 
//  - Dùng driver pg
//  - Sinh đúng chuẩn Postgre
datasource db {
  provider = "postgresql"
}

enum MemberRole {
  OWNER
  CO_OWNER
  MEMBER
}

enum MessageType {
  DIRECT
  GROUP
}

enum MessageStatus {
  SENT
  RECALLED
  DELETED
}

enum CardFieldType {
  TEXT
  TEXTAREA
  IMAGE
}

enum CardSide {
  FRONT
  BACK
}

enum VoteType {
  UPVOTE
  DOWNVOTE
}

enum SocialPlatform {
  FACEBOOK
  INSTAGRAM
  TWITTER
  YOUTUBE
  TIKTOK
  LINKEDIN
  CUSTOM
}

enum VisibilityScope {
  EVERYONE
  FRIENDS
  PRIVATE
}

enum NotificationType {
  CHAT_DIRECT
  CHAT_GROUP
  SYSTEM
  COMMENT
  UPVOTE
  FOLLOW
  NEW_BLOG_POST
}

enum NotificationChannel {
  EMAIL
  INBOX
  OFF
}

model User {
  id                 String  @id @default(uuid())
  username           String  @unique
  hashedPassword     String?
  googleId           String? @unique
  isTwoFactorEnabled Boolean @default(false)
  twoFactorSecret    String?

  fullName  String
  email     String    @unique
  avatar    String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // Relations
  sentMessages      Message[]          @relation("Sender")
  receivedMessages  Message[]          @relation("Receiver")
  ownedGroups       Group[]            @relation("Owner")
  groupMemberships  GroupMember[]
  seenMessages      MessageSeen[]
  refreshTokens     RefreshToken[]
  blogs             Blog[]             @relation("BlogAuthor")
  comments          Comment[]          @relation("CommentAuthor")
  blogVotes         BlogVote[]         @relation("UserBlogVotes")
  commentVotes      CommentVote[]      @relation("UserCommentVotes")
  grammarStructures GrammarStructure[] @relation("GrammarAuthor")
  cardCollections   CardCollection[]
  cardTypes         CardType[]
  socials           UserSocial[]

  following Follow[] @relation("UserFollowing")
  followers Follow[] @relation("UserFollowers")

  privacySettings UserPrivacySetting?

  blocking Block[] @relation("UserBlocking")
  blocked  Block[] @relation("UserBlocked")

  receivedNotifications Notification[] @relation("NotificationRecipient")
  sentNotifications     Notification[] @relation("NotificationSender")

  notificationSettings NotificationSetting?
  reminders            Reminder[]
  devices              UserDevice[]

  @@map("users")
}

model Follow {
  followerId  String
  followingId String
  createdAt   DateTime @default(now())
  follower    User     @relation("UserFollowing", fields: [followerId], references: [id], onDelete: Cascade)
  following   User     @relation("UserFollowers", fields: [followingId], references: [id], onDelete: Cascade)

  @@id([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
  @@map("follows")
}

model Block {
  blockingId String
  blockedId  String
  createdAt  DateTime @default(now())

  blockingUser User @relation("UserBlocking", fields: [blockingId], references: [id], onDelete: Cascade)
  blockedUser  User @relation("UserBlocked", fields: [blockedId], references: [id], onDelete: Cascade)

  @@id([blockingId, blockedId])
  @@index([blockingId])
  @@index([blockedId])
  @@map("blocks")
}

model UserSocial {
  id       String         @id @default(uuid())
  userId   String
  platform SocialPlatform
  name     String?
  link     String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // relation
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_socials")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  ipAddress String?
  userAgent String?
  isRevoked Boolean  @default(false)
  expiresAt DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([expiresAt])
  @@map("refresh_tokens")
}

model Message {
  id          String        @id @default(uuid())
  type        MessageType   @default(DIRECT)
  senderId    String
  receiverId  String?
  groupId     String?
  content     String?
  replyTo     String?
  attachments Json?
  status      MessageStatus @default(SENT)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // Relations
  sender   User   @relation("Sender", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User?  @relation("Receiver", fields: [receiverId], references: [id], onDelete: Cascade)
  group    Group? @relation(fields: [groupId], references: [id], onDelete: Cascade)

  reply   Message?  @relation("Reply", fields: [replyTo], references: [id], onDelete: SetNull)
  replies Message[] @relation("Reply")

  seenBy MessageSeen[]

  @@index([senderId])
  @@index([receiverId])
  @@index([groupId])
  @@index([replyTo])
  @@index([createdAt])
  @@index([groupId, createdAt])
  @@index([receiverId, createdAt])
  @@map("messages")
}

model MessageSeen {
  userId    String
  messageId String
  seenAt    DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@id([userId, messageId])
  @@index([messageId])
  @@index([userId, seenAt])
  @@map("message_seen")
}

model Group {
  id          String   @id @default(uuid())
  name        String
  avatar      String?
  description String?
  ownerId     String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  owner           User                  @relation("Owner", fields: [ownerId], references: [id], onDelete: Cascade)
  members         GroupMember[]
  messages        Message[]
  rolePermissions GroupRolePermission[]
  notifications   Notification[]

  @@index([ownerId])
  @@map("groups")
}

model GroupMember {
  id       String     @id @default(uuid())
  groupId  String
  userId   String
  role     MemberRole @default(MEMBER)
  joinedAt DateTime   @default(now())

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@index([groupId])
  @@index([userId])
  @@map("group_members")
}

// 1. Định nghĩa các hành động có thể có trong hệ thống
model Permission {
  id          String                @id @default(uuid())
  name        String                @unique
  description String?
  roles       GroupRolePermission[]

  @@map("permissions")
}

// 2. Bảng gán quyền cho từng Role trong từng Nhóm
model GroupRolePermission {
  id           String     @id @default(uuid())
  groupId      String
  role         MemberRole
  permissionId String
  isEnabled    Boolean    @default(true)

  group      Group      @relation(fields: [groupId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([groupId, role, permissionId])
  @@index([groupId])
  @@index([permissionId])
  @@map("group_role_permissions")
}

// ==================== BLOG ====================

model Blog {
  id         String    @id @default(uuid())
  title      String
  content    String
  excerpt    String?
  coverImage String?
  authorId   String
  isPublic   Boolean   @default(true)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?

  author   User       @relation("BlogAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  comments Comment[]
  votes    BlogVote[]

  @@index([authorId])
  @@index([isPublic, createdAt])
  @@map("blogs")
}

model Comment {
  id              String    @id @default(uuid())
  content         String
  blogId          String
  authorId        String
  parentCommentId String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  blog          Blog          @relation(fields: [blogId], references: [id], onDelete: Cascade)
  author        User          @relation("CommentAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  replies       Comment[]     @relation("CommentReplies")
  parentComment Comment?      @relation("CommentReplies", fields: [parentCommentId], references: [id])
  votes         CommentVote[]

  @@index([blogId])
  @@index([authorId])
  @@index([parentCommentId])
  @@map("comments")
}

model BlogVote {
  userId    String
  blogId    String
  type      VoteType
  createdAt DateTime @default(now())

  user User @relation("UserBlogVotes", fields: [userId], references: [id], onDelete: Cascade)
  blog Blog @relation(fields: [blogId], references: [id], onDelete: Cascade)

  @@id([userId, blogId])
  @@map("blog_votes")
}

model CommentVote {
  userId    String
  commentId String
  type      VoteType
  createdAt DateTime @default(now())

  user    User    @relation("UserCommentVotes", fields: [userId], references: [id], onDelete: Cascade)
  comment Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@id([userId, commentId])
  @@map("comment_votes")
}

// ==================== GRAMMAR ======================

model GrammarStructure {
  id          String   @id @default(uuid())
  title       String
  structure   String
  explanation String
  examples    Json?
  category    String?
  level       String?
  isDefault   Boolean  @default(false)
  authorId    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  author User? @relation("GrammarAuthor", fields: [authorId], references: [id], onDelete: Cascade)

  @@index([category])
  @@index([level])
  @@map("grammar_structures")
}

// ==================== VOCABULARY ====================

model CardCollection {
  id          String   @id @default(uuid())
  name        String
  description String?
  userId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  cards Card[]

  @@index([userId])
  @@map("card_collections")
}

model CardType {
  id          String   @id @default(uuid())
  name        String
  description String?
  userId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user   User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  fields CardField[]
  cards  Card[]

  @@unique([userId, name])
  @@index([userId])
  @@map("card_type")
}

model CardField {
  id         String        @id @default(uuid())
  cardTypeId String
  key        String
  label      String
  fieldType  CardFieldType

  side CardSide

  order     Int
  color     String?
  fontSize  Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cardType CardType         @relation(fields: [cardTypeId], references: [id], onDelete: Cascade)
  values   CardFieldValue[]

  @@unique([cardTypeId, key])
  @@index([cardTypeId])
  @@index([cardTypeId, order])
  @@index([cardTypeId, side, order])
  @@map("card_field")
}

model Card {
  id               String @id @default(uuid())
  cardTypeId       String
  cardCollectionId String
  position         Int?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  cardType       CardType       @relation(fields: [cardTypeId], references: [id], onDelete: Cascade)
  cardCollection CardCollection @relation(fields: [cardCollectionId], references: [id], onDelete: Cascade)

  values CardFieldValue[]

  @@index([cardTypeId])
  @@index([cardCollectionId, createdAt])
  @@index([cardCollectionId, position])
  @@map("card")
}

model CardFieldValue {
  id String @id @default(uuid())

  cardId  String
  fieldId String

  value String

  card  Card      @relation(fields: [cardId], references: [id], onDelete: Cascade)
  field CardField @relation(fields: [fieldId], references: [id], onDelete: Cascade)

  @@unique([cardId, fieldId])
  @@index([cardId])
  @@index([fieldId])
  @@index([cardId, fieldId])
  @@map("card_field_value")
}

// ==================== PRIVACY SETTINGS ====================
model UserPrivacySetting {
  id                     String          @id @default(uuid())
  userId                 String          @unique
  allowFollow            Boolean         @default(true)
  messageScope           VisibilityScope @default(EVERYONE)
  followersTabVisibility VisibilityScope @default(EVERYONE)
  followingTabVisibility VisibilityScope @default(EVERYONE)
  friendTabVisibility    VisibilityScope @default(EVERYONE)
  updatedAt              DateTime        @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_privacy_settings")
}

model NotificationSetting {
  id                   String              @id @default(uuid())
  userId               String              @unique
  chatMessages         NotificationChannel @default(INBOX)
  comments             NotificationChannel @default(INBOX)
  upvotes              NotificationChannel @default(INBOX)
  newFollowers         NotificationChannel @default(INBOX)
  activityFromFollowed NotificationChannel @default(INBOX)
  updatedAt            DateTime            @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notification_settings")
}

model Notification {
  id          String           @id @default(uuid())
  recipientId String?
  groupId     String?
  senderId    String?
  type        NotificationType @default(CHAT_DIRECT)
  content     String?
  isRead      Boolean          @default(false)
  metadata    Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  recipient User?  @relation("NotificationRecipient", fields: [recipientId], references: [id], onDelete: Cascade)
  group     Group? @relation(fields: [groupId], references: [id], onDelete: Cascade)
  sender    User?  @relation("NotificationSender", fields: [senderId], references: [id], onDelete: SetNull)

  @@index([recipientId])
  @@index([recipientId, isRead])
  @@index([createdAt(sort: Desc)])
  @@map("notifications")
}

enum ReminderType {
  ON_THE_HOUR
  EVERY_5_MINUTES
  EVERY_10_MINUTES
  EVERY_15_MINUTES
  EVERY_30_MINUTES
  EVERY_HOUR
  EVERY_2_HOURS
  EVERY_3_HOURS
  EVERY_4_HOURS
  EVERY_6_HOURS
  EVERY_8_HOURS
}

model Reminder {
  id          String       @id @default(uuid())
  userId      String
  title       String
  description String?
  type        ReminderType
  isEnabled   Boolean      @default(true)
  
  // Example: 08:30 = (8 * 60) + 30 = 510
  triggerTime Int?        
  startTime   Int?        
  endTime     Int?        
  
  // Array of days (0 = Sunday, 6 = Saturday)
  daysOfWeek  Int[]   

  schedulerId String       @unique

  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  deletedAt   DateTime?

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isEnabled])
  @@map("reminders")
}

model UserDevice {
  id        String   @id @default(uuid())
  userId    String
  fcmToken  String   @unique
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_devices")
}